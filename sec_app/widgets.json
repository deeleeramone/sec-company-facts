  "sec_top_companies": {
    "name": "Top Companies by Metric",
    "description": "Ranks companies by a standardized financial metric using the most recent full-year (annual) filing. All values converted to USD.",
    "category": "Financial Statements",
    "type": "table",
    "endpoint": "top_companies",
    "gridData": {
      "w": 40,
      "h": 20
    },
    "data": {
      "table": {
        "enableAdvanced": true,
        "showAll": true,
        "columnsDefs": [
          {
            "field": "ticker",
            "headerName": "Ticker",
            "cellDataType": "text"
          },
          {
            "field": "name",
            "headerName": "Company",
            "cellDataType": "text"
          },
          {
            "field": "period_ending",
            "headerName": "Period Ending",
            "cellDataType": "text"
          },
          {
            "field": "fiscal_year",
            "headerName": "FY",
            "cellDataType": "text"
          },
          {
            "field": "fiscal_period",
            "headerName": "Period",
            "cellDataType": "text"
          },
          {
            "field": "currency",
            "headerName": "Reported Currency",
            "cellDataType": "text",
            "hide": true
          },
          {
            "field": "value",
            "headerName": "Value",
            "cellDataType": "number"
          }
        ]
      }
    },
    "params": [
      {
        "type": "endpoint",
        "paramName": "metric",
        "label": "Metric",
        "value": "income_statement|total_revenue",
        "description": "Financial metric to rank companies by.",
        "optionsEndpoint": "/metrics",
        "searchable": false
      },
      {
        "type": "number",
        "paramName": "limit",
        "label": "Top N",
        "value": 25,
        "description": "Number of companies to return."
      },
      {
        "type": "endpoint",
        "paramName": "sector",
        "label": "Sector",
        "value": "",
        "description": "Optional. Restrict the ranking to one sector. Narrows the Industry choices.",
        "optionsEndpoint": "/sectors",
        "searchable": true
      },
      {
        "type": "endpoint",
        "paramName": "industry",
        "label": "Industry",
        "value": "",
        "description": "Optional. Restrict the ranking to one industry (choices depend on Sector).",
        "optionsEndpoint": "/industries",
        "searchable": true
      }
    ]
  },
  "sec_sector_aggregates": {
    "name": "Sector & Industry Aggregates",
    "description": "Operating statistics by sector, or by industry within a sector. GICS-like reclassification of SIC: Health Care carved out across divisions, cannabis treated as Agriculture. Leave Industry blank for sector-level rows.",
    "category": "Aggregates",
    "type": "table",
    "endpoint": "sector_aggregates",
    "refetchInterval": false,
    "gridData": {
      "w": 40,
      "h": 18
    },
    "data": {
      "table": {
        "enableAdvanced": true,
        "showAll": true,
        "columnsDefs": [
          {
            "field": "Sector",
            "headerName": "Sector",
            "cellDataType": "text"
          },
          {
            "field": "Industry",
            "headerName": "Industry",
