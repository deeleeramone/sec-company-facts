      }
    },
    "params": [
      {
        "type": "endpoint",
        "paramName": "sector",
        "label": "Sector",
        "value": "",
        "description": "Pick a sector to narrow the Industry choices and scope the table. Leave blank for all sectors.",
        "optionsEndpoint": "/sectors",
        "searchable": true
      },
      {
        "type": "endpoint",
        "paramName": "industry",
        "label": "Industry",
