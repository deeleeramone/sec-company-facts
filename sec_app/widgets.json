{
  "sec_balance_sheet": {
    "name": "Balance Sheet",
    "description": "SEC standardized balance sheet (annual / quarterly / TTM, with optional YoY / PoP transform).",
    "category": "Financial Statements",
    "type": "table",
    "endpoint": "balance_sheet",
    "refetchInterval": false,
    "gridData": {
      "w": 40,
      "h": 18
    },
    "data": {
      "table": {
        "enableAdvanced": true,
        "showAll": true,
        "columnsDefs": [
          {
            "field": "Line Item",
            "headerName": "Line Item",
            "cellDataType": "text",
            "renderFn": "hoverCard",
            "renderFnParams": {
              "hoverCard": {
                "cellField": "value",
                "title": "",
                "markdown": "### {Line Item}\n\n{description}\n\n### Source Provenance\n{provenance}"
              }
            }
          },
          {
            "field": "description",
            "headerName": "Description",
            "cellDataType": "text",
            "hide": true
          },
          {
            "field": "provenance",
            "headerName": "Source Provenance",
            "cellDataType": "text",
            "hide": true
          }
        ]
      }
    },
    "params": [
      {
        "type": "endpoint",
        "paramName": "symbol",
        "label": "Symbol",
        "value": "AAPL",
        "description": "Pick a company (ranked by SEC market-cap order).",
        "optionsEndpoint": "/companies",
        "searchable": true,
        "style": {
          "popupWidth": 950
        }
      },
      {
        "type": "tabs",
        "paramName": "period",
        "label": "Period",
        "value": "FY",
        "description": "FY = annual, Q = quarterly, TTM = trailing twelve months. Foreign issuers without quarterly filings will return empty for Q / TTM.",
        "options": [
          {
            "label": "FY",
            "value": "FY"
          },
          {
            "label": "Q",
            "value": "Q"
          },
          {
            "label": "TTM",
            "value": "TTM"
          }
        ]
      },
      {
        "type": "tabs",
        "paramName": "transform",
        "label": "Transform",
        "value": "None",
        "description": "None = raw values; % YoY = year-over-year %; % PoP = period-over-period %. Valid combos: FY+%YoY, Q+%YoY, Q+%PoP, TTM+%PoP.",
        "options": [
          {
            "label": "$",
            "value": "None"
          },
          {
            "label": "% YoY",
            "value": "% YoY"
          },
          {
            "label": "% PoP",
            "value": "% PoP"
          }
        ]
      },
      {
        "type": "boolean",
        "paramName": "transpose",
        "label": "Transpose",
        "value": true,
        "description": "Pivot the table so line items are rows and periods are columns."
      },
      {
        "type": "number",
        "paramName": "limit",
        "label": "Limit",
        "value": 10,
        "description": "Most-recent N periods (0 = all)."
      },
      {
        "type": "boolean",
        "paramName": "convert_to_usd",
        "label": "Convert to USD",
        "value": true,
        "description": "Convert reported values to USD using historical ECB exchange rates. Disable to see native reporting currency."
      }
    ]
  },
