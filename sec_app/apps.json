  "tabs": {
    "financial-statements": {
      "id": "financial-statements",
      "name": "Financial Statements",
      "layout": [
        {
          "i": "sec_balance_sheet",
          "x": 0,
          "y": 0,
          "w": 40,
          "h": 18,
          "state": {
            "params": {
              "symbol": "AAPL",
              "period": "FY",
              "transform": null,
              "transpose": true,
              "limit": 10
            }
          }
        },
        {
          "i": "sec_income_statement",
          "x": 0,
          "y": 18,
          "w": 40,
          "h": 18,
          "state": {
            "params": {
              "symbol": "AAPL",
              "period": "FY",
              "transform": null,
              "transpose": true,
              "limit": 10
            }
          }
        },
        {
          "i": "sec_cash_flow",
          "x": 0,
          "y": 36,
          "w": 40,
          "h": 18,
          "state": {
            "params": {
              "symbol": "AAPL",
              "period": "FY",
              "transform": null,
              "transpose": true,
              "limit": 10
            }
          }
        }
      ]
    },
    "rankings": {
      "id": "rankings",
      "name": "Rankings",
      "layout": [
        {
          "i": "sec_top_companies",
          "x": 0,
          "y": 0,
          "w": 40,
          "h": 20,
          "state": {
            "params": {
              "metric": "income_statement|total_revenue",
              "limit": 25,
              "sector": null,
              "industry": null
            }
          }
        },
        {
          "i": "sec_sector_aggregates",
          "x": 0,
          "y": 20,
          "w": 40,
          "h": 18,
          "state": {
            "params": {
              "sector": null,
              "industry": null
            }
          }
        }
      ]
    }
  },
  "groups": [
    {
      "name": "Symbol",
      "type": "endpointParam",
      "paramName": "symbol",
      "defaultValue": "AAPL",
      "widgetIds": [
        "sec_balance_sheet",
        "sec_income_statement",
        "sec_cash_flow"
      ]
    },
    {
      "name": "Period",
      "type": "param",
      "paramName": "period",
      "defaultValue": "FY",
      "widgetIds": [
        "sec_balance_sheet",
        "sec_income_statement",
        "sec_cash_flow"
      ]
    },
    {
      "name": "Transform",
      "type": "param",
      "paramName": "transform",
      "defaultValue": null,
      "widgetIds": [
        "sec_balance_sheet",
        "sec_income_statement",
        "sec_cash_flow"
      ]
    },
    {
      "name": "Transpose",
      "type": "param",
      "paramName": "transpose",
      "defaultValue": true,
      "widgetIds": [
        "sec_balance_sheet",
        "sec_income_statement",
        "sec_cash_flow"
      ]
    },
    {
      "name": "Limit",
      "type": "param",
      "paramName": "limit",
      "defaultValue": 10,
      "widgetIds": [
        "sec_balance_sheet",
        "sec_income_statement",
        "sec_cash_flow"
      ]
    },
    {
      "name": "Currency",
      "type": "param",
      "paramName": "convert_to_usd",
      "defaultValue": true,
      "widgetIds": [
        "sec_balance_sheet",
        "sec_income_statement",
        "sec_cash_flow"
      ]
    }
  ]
}